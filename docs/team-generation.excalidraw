      "isDeleted": true,
      "boundElements": null,
      "updated": 1776671961250,
      "link": null,
      "locked": false,
      "text": "In case the max is reached and the player selects again a\nprevious selected position, then the",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In case the max is reached and the player selects again a previous selected position, then the",
      "autoResize": false,
      "lineHeight": 1.25
    },
